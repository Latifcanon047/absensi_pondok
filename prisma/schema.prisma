generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum TipeAbsensi {
  SHOLAT
  KELAS
  MAKAN
  ASRAMA
}

enum StatusAbsen {
  HADIR
  SAKIT
  IZIN
  ALPA
  TELAT
  KOSONG
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Santri {
  id          Int          @id @default(autoincrement())
  nama        String
  isArchived  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  absenSholat AbsenSholat[]
  absenKelas  AbsenKelas[]
  absenMakan  AbsenMakan[]
  absenAsrama AbsenAsrama[]
}

model Absensi {
  id          Int           @id @default(autoincrement())
  tipe        TipeAbsensi
  tanggal     DateTime
  createdAt   DateTime      @default(now())
  absenSholat AbsenSholat[]
  absenKelas  AbsenKelas[]
  absenMakan  AbsenMakan[]
  absenAsrama AbsenAsrama[]

  @@unique([tipe, tanggal])
}

model AbsenSholat {
  id        Int         @id @default(autoincrement())
  absensiId Int
  santriId  Int
  waktu     String
  status    StatusAbsen @default(KOSONG)
  absensi   Absensi     @relation(fields: [absensiId], references: [id], onDelete: Cascade)
  santri    Santri      @relation(fields: [santriId], references: [id], onDelete: Restrict)

  @@unique([absensiId, santriId, waktu])
}

model AbsenKelas {
  id        Int         @id @default(autoincrement())
  absensiId Int
  santriId  Int
  sesi      String
  status    StatusAbsen @default(KOSONG)
  absensi   Absensi     @relation(fields: [absensiId], references: [id], onDelete: Cascade)
  santri    Santri      @relation(fields: [santriId], references: [id], onDelete: Restrict)

  @@unique([absensiId, santriId, sesi])
}

model AbsenMakan {
  id        Int         @id @default(autoincrement())
  absensiId Int
  santriId  Int
  sesi      String      // "Pagi" | "Siang" | "Sore"
  status    StatusAbsen @default(KOSONG)
  absensi   Absensi     @relation(fields: [absensiId], references: [id], onDelete: Cascade)
  santri    Santri      @relation(fields: [santriId], references: [id], onDelete: Restrict)

  @@unique([absensiId, santriId, sesi])
}

model AbsenAsrama {
  id        Int         @id @default(autoincrement())
  absensiId Int
  santriId  Int
  status    StatusAbsen @default(KOSONG)
  absensi   Absensi     @relation(fields: [absensiId], references: [id], onDelete: Cascade)
  santri    Santri      @relation(fields: [santriId], references: [id], onDelete: Restrict)

  @@unique([absensiId, santriId])
}